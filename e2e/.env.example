# E2E test configuration — copy to e2e/.env and fill in values
# e2e/.env is gitignored and never committed

# ── Required ──────────────────────────────────────────────────────────────────
# These must be set — the suite will fail immediately with a clear error if missing.

# PDS core URL
E2E_PDS_URL=https://karmas-e2e-pds.up.railway.app

# Auth service URL
E2E_AUTH_URL=https://certified-e2e-auth.up.railway.app

# Demo app URL
E2E_DEMO_URL=https://certified-appdemo-production.up.railway.app

# ── Mailpit ───────────────────────────────────────────────────────────────────
# Required for OTP email scenarios. Leave E2E_MAILPIT_PASS empty to skip them.

E2E_MAILPIT_URL=https://mailpit-e2e-karma-test.up.railway.app
E2E_MAILPIT_USER=karma
E2E_MAILPIT_PASS=

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to 'true' to run headless (no visible browser window). Default: false.
# E2E_HEADLESS=false
