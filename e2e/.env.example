# E2E test configuration — copy to e2e/.env and fill in values
# e2e/.env is gitignored and never committed

# ── Required ──────────────────────────────────────────────────────────────────
# These must be set — the suite will fail immediately with a clear error if missing.

# PDS core URL
E2E_PDS_URL=https://pds.example.com

# Auth service URL
E2E_AUTH_URL=https://auth.example.com

# Demo app URL
E2E_DEMO_URL=https://demo.example.com

# ── Mailpit ───────────────────────────────────────────────────────────────────
# Required for OTP email scenarios. Leave E2E_MAILPIT_PASS empty to skip them.

E2E_MAILPIT_URL=https://mailpit.example.com
E2E_MAILPIT_USER=admin
E2E_MAILPIT_PASS=

# ── Internal API ──────────────────────────────────────────────────────────────
# Required for internal-api.feature scenarios. Leave empty to skip them.
# Must match EPDS_INTERNAL_SECRET on the pds-core service.
# Copy from the root .env file — it mirrors the Railway environment.
E2E_EPDS_INTERNAL_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to 'true' to run headless (no visible browser window). Default: false.
# E2E_HEADLESS=false
